# Security Headers - Always set first
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    # Remove Server Information
    Header unset Server
    Header unset X-Powered-By

    # Cache Control for Assets
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
</IfModule>

# Prevent access to sensitive files
<FilesMatch "(^#.*#|\.(bak|conf|dist|fla|in[ci]|log|orig|psd|sh|sql|sw[op])|~)$">
    Order allow,deny
    Deny from all
    Satisfy All
</FilesMatch>

# Block access to configuration files
<FilesMatch "\.(env|git|htaccess|htpasswd)">
    Order allow,deny
    Deny from all
    Satisfy All
</FilesMatch>

# Block access to Laravel specific directories in public_html deployment
RewriteEngine On
RewriteRule ^(laravel|application)/ - [F,L]

# Block access to common development/config files
<FilesMatch "(composer\.(json|lock)|package\.(json|lock)|\.env|artisan)$">
    Order allow,deny
    Deny from all
    Satisfy All
</FilesMatch>

# Prevent access to installer after installation (if exists)
<IfModule mod_rewrite.c>
    # Block installer directory if installation is complete
    RewriteCond %{REQUEST_URI} ^/install/
    RewriteCond %{DOCUMENT_ROOT}/../laravel/.env -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/application/.env -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/../.env -f
    RewriteRule ^install/ - [F,L]
</IfModule>

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Disable server signature
ServerSignature Off

# Prevent access to version control directories
RedirectMatch 404 /\.git

# Security: Don't allow php execution in uploads
<Directory "*/storage/app/public">
    php_flag engine off
    AddType text/plain .php .php3 .phtml .pht
</Directory>

# Custom Error Pages
ErrorDocument 403 /errors/403.html
ErrorDocument 404 /errors/404.html
ErrorDocument 500 /errors/500.html